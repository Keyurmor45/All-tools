{
  "manifest_version": 3,
  "name": "AllTools — 136+ Free Online Tools",
  "short_name": "AllTools",
  "description": "136+ free tools for text, code, math, design & security — right in your new tab. No login, no ads, runs 100% in your browser.",
  "version": "1.0.0",
  "author": "keyurmor45",

  "chrome_url_overrides": {
    "newtab": "index.html"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "style.css",
        "app-core.js",
        "tools-1.js",
        "tools-2.js",
        "tools-3.js",
        "app-init.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
